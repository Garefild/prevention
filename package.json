{
    "name": "prevention",
    "main": "dist/cjs/index.js",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/esm/index.js",
    "version": "1.0.0-local",
    "license": "MIT",
    "description": "Prevent shipping unminified, commented, or blacklisted JavaScript. Validates a dist folder before publish.",
    "sideEffects": false,
    "engines": {
        "node": ">=22"
    },
    "bin": {
        "prevention": "dist/esm/cli.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "dev":              "xBuild -w",
        "build":            "xBuild",
        "build:clean":      "rm -rf ./dist && xBuild",

        "test":             "xjet",
        "test:coverage":    "xjet --coverage",

        "lint":             "pnpm lint:eslint && pnpm lint:typescript",
        "lint:eslint":      "eslint . -c ./eslint.config.mjs",
        "lint:typescript":  "xBuild --tc"
    },
    "dependencies": {
        "yargs": "^18.0.0",
        "acorn": "^8.12.0",
        "acorn-walk": "^8.3.0",
        "@remotex-labs/xansi": "^1.3.7"
    },
    "devDependencies": {
        "@types/node": "^25.9.2",
        "@types/yargs": "^17.0.35",
        "@remotex-labs/xjet": "^1.5.4",
        "@remotex-labs/xbuild": "^2.5.1",
        "eslint": "^10.4.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "eslint-plugin-tsdoc": "^0.5.0",
        "eslint-plugin-perfectionist": "^5.9.0"
    }
}
